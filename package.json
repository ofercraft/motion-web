{
  "name": "motion-web",
  "version": "0.6.0",
  "description": "Framework-independent expressive motion buttons as native Web Components.",
  "type": "module",
  "sideEffects": true,
  "scripts": {
    "start": "ng serve motion-web-demo",
    "build": "ng build motion-web-demo"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./motion-button": {
      "types": "./src/motion-button.d.ts",
      "import": "./src/motion-button.js"
    },
    "./motion-split-button": {
      "types": "./src/motion-split-button.d.ts",
      "import": "./src/motion-split-button.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "web-components",
    "custom-elements",
    "material-design",
    "motion"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ofercraft/motion-web.git"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.18",
    "@angular/animations": "^21.2.18",
    "@angular/cdk": "^21.2.14",
    "@angular/cli": "^21.2.18",
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/compiler-cli": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.18",
    "rxjs": "^7.8.2",
    "sass": "^1.101.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
